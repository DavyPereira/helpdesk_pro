<div class="p-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-on-surface">Dashboard</h1>
    <p class="text-sm text-on-surface-variant mt-1">Visão geral da operação de suporte.</p>
  </div>

  <!-- KPI Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 mb-8">
    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Total</p>
      <p class="text-3xl font-bold text-on-surface"><%= @total_tickets %></p>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Abertos</p>
      <p class="text-3xl font-bold text-primary"><%= @open_tickets %></p>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Em andamento</p>
      <p class="text-3xl font-bold text-yellow-400"><%= @progress_tickets %></p>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Resolvidos</p>
      <p class="text-3xl font-bold text-on-surface"><%= @resolved_tickets %></p>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Alta prioridade</p>
      <p class="text-3xl font-bold text-red-400"><%= @high_priority_tickets %></p>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Atrasados</p>
      <p class="text-3xl font-bold text-red-400"><%= @late_tickets %></p>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 hover:border-primary/30 transition-colors">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Vencendo</p>
      <p class="text-3xl font-bold text-yellow-400"><%= @due_soon_tickets %></p>
    </div>
  </div>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">donut_large</span>
        Chamados por status
      </h2>
      <%= pie_chart @tickets_by_status, colors: ["#4edea3", "#f59e0b", "#94a3b8"] %>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">bar_chart</span>
        Chamados por prioridade
      </h2>
      <%= column_chart @tickets_by_priority, colors: ["#4edea3"] %>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">show_chart</span>
        Chamados criados por dia
      </h2>
      <%= line_chart @tickets_by_day, colors: ["#4edea3"] %>
    </div>

    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-6">
      <h2 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">timer</span>
        Situação do SLA
      </h2>
      <%= pie_chart @tickets_by_sla, colors: ["#4edea3", "#f59e0b", "#ef4444", "#94a3b8"] %>
    </div>
  </div>

  <!-- Recent tickets -->
  <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-6">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-sm font-semibold text-on-surface flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">receipt_long</span>
        Chamados recentes
      </h2>
      <%= link_to new_ticket_path,
        class: "flex items-center gap-2 h-9 px-4 gradient-emerald text-on-primary text-xs font-bold rounded-xl shadow-primary/20 hover:shadow-primary/30 transition-all" do %>
        <span class="material-symbols-outlined text-base">add</span>
        Novo chamado
      <% end %>
    </div>

    <% if @recent_tickets.any? %>
      <div class="space-y-3">
        <% @recent_tickets.each do |ticket| %>
          <div class="flex items-center justify-between p-4 bg-surface-container-low border border-outline-variant/20 rounded-xl hover:border-primary/30 transition-colors">
            <div class="min-w-0">
              <p class="font-semibold text-on-surface text-sm truncate"><%= ticket.title %></p>
              <p class="text-xs text-on-surface-variant mt-1">
                <%= ticket.status.humanize %> &middot;
                <%= ticket.priority.humanize %> &middot;
                SLA: <%= ticket.sla_status.humanize %>
              </p>
            </div>
            <%= link_to "Ver",
              ticket_path(ticket),
              class: "ml-4 text-xs font-semibold text-primary hover:underline underline-offset-2 shrink-0" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-10">
        <span class="material-symbols-outlined text-outline text-4xl mb-2 block">inbox</span>
        <p class="text-sm text-on-surface-variant">Nenhum chamado criado ainda.</p>
      </div>
    <% end %>
  </div>
</div>

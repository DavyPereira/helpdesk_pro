<div class="p-8">
  <div class="flex justify-between items-start mb-8">
    <div>
      <h1 class="text-2xl font-bold text-on-surface">Chamados</h1>
      <p class="text-sm text-on-surface-variant mt-1">
        <% if current_user.admin? %>
          Visualizando todos os chamados do sistema.
        <% else %>
          Visualizando apenas seus chamados.
        <% end %>
      </p>
    </div>

    <%= link_to new_ticket_path,
      class: "flex items-center gap-2 h-10 px-5 gradient-emerald text-on-primary text-sm font-bold rounded-xl shadow-primary/20 hover:shadow-primary/30 transition-all" do %>
      <span class="material-symbols-outlined text-base">add</span>
      Novo Chamado
    <% end %>
  </div>

  <!-- Filters -->
  <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-4 mb-6">
    <%= form_with url: tickets_path, method: :get, local: true,
      class: "flex gap-4 items-end flex-wrap" do %>

      <div>
        <label class="block text-xs font-medium text-on-surface-variant mb-1.5">Pesquisar</label>
        <%= text_field_tag :query, params[:query],
          placeholder: "Buscar por título...",
          class: "h-10 bg-surface-container-low border border-outline-variant/40 rounded-xl px-3 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-on-surface-variant mb-1.5">Status</label>
        <%= select_tag :status,
          options_for_select([["Todos", ""]] + Ticket.statuses.keys.map { |s| [s, s] }, params[:status]),
          class: "h-10 bg-surface-container-low border border-outline-variant/40 rounded-xl px-3 text-sm text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-on-surface-variant mb-1.5">Prioridade</label>
        <%= select_tag :priority,
          options_for_select([["Todas", ""]] + Ticket.priorities.keys.map { |p| [p, p] }, params[:priority]),
          class: "h-10 bg-surface-container-low border border-outline-variant/40 rounded-xl px-3 text-sm text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" %>
      </div>

      <%= submit_tag "Filtrar",
        class: "h-10 px-5 gradient-emerald text-on-primary text-sm font-bold rounded-xl cursor-pointer transition-all" %>

      <%= link_to "Limpar", tickets_path,
        class: "h-10 px-5 flex items-center bg-surface-container-high border border-outline-variant/20 text-on-surface-variant text-sm rounded-xl hover:border-outline/50 transition-all" %>
    <% end %>
  </div>

  <!-- Table -->
  <div class="bg-surface-container border border-outline-variant/20 rounded-xl overflow-hidden">
    <table class="min-w-full">
      <thead class="bg-surface-container-high border-b border-outline-variant/20">
        <tr>
          <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Título</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Status</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Prioridade</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">SLA</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Responsável</th>
          <% if current_user.admin? %>
            <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Usuário</th>
          <% end %>
          <th class="text-left px-6 py-3 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Ações</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-outline-variant/10">
        <% if @tickets.any? %>
          <% @tickets.each do |ticket| %>
            <tr class="hover:bg-surface-container-high/50 transition-colors">
              <td class="px-6 py-4 text-sm font-medium text-on-surface"><%= ticket.title %></td>

              <td class="px-6 py-4">
                <span class="chip <%= case ticket.status
                    when 'open'        then 'chip-emerald'
                    when 'in_progress' then 'chip-yellow'
                    when 'resolved'    then 'chip-blue'
                    end %>">
                  <%= ticket.status.humanize %>
                </span>
              </td>

              <td class="px-6 py-4">
                <span class="chip <%= case ticket.priority
                    when 'low'    then 'chip-gray'
                    when 'medium' then 'chip-yellow'
                    when 'high'   then 'chip-red'
                    end %>">
                  <%= ticket.priority.humanize %>
                </span>
              </td>

              <td class="px-6 py-4">
                <span class="chip <%= case ticket.sla_status
                    when 'atrasado'  then 'chip-red'
                    when 'vencendo'  then 'chip-yellow'
                    when 'no prazo'  then 'chip-emerald'
                    when 'resolvido' then 'chip-blue'
                    else 'chip-gray'
                    end %>">
                  <%= ticket.sla_status.humanize %>
                </span>
                <p class="text-xs text-on-surface-variant mt-1">SLA: <%= ticket.sla_hours %>h</p>
                <p class="text-xs text-on-surface-variant">Criado: <%= l(ticket.created_at, format: :short) %></p>
                <% if ticket.due_at.present? %>
                  <p class="text-xs text-on-surface-variant">Prazo: <%= l(ticket.due_at, format: :short) %></p>
                <% end %>
              </td>

              <td class="px-6 py-4 text-sm text-on-surface-variant">
                <%= ticket.assigned_to&.email || "—" %>
              </td>

              <% if current_user.admin? %>
                <td class="px-6 py-4 text-sm text-on-surface-variant"><%= ticket.user.email %></td>
              <% end %>

              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <%= link_to "Ver", ticket,
                    class: "text-xs font-semibold text-primary hover:underline underline-offset-2" %>
                  <%= link_to "Editar", edit_ticket_path(ticket),
                    class: "text-xs font-semibold text-on-surface-variant hover:text-on-surface transition-colors" %>
                  <%= button_to "Excluir", ticket,
                    method: :delete,
                    data: { turbo_confirm: "Tem certeza?" },
                    class: "text-xs font-semibold text-red-400 hover:text-red-300 transition-colors cursor-pointer" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="<%= current_user.admin? ? 7 : 6 %>" class="px-6 py-16 text-center">
              <span class="material-symbols-outlined text-outline text-4xl mb-2 block">inbox</span>
              <p class="text-sm text-on-surface-variant">Nenhum chamado encontrado.</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="p-8 max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-6 flex items-start gap-3">
    <%= link_to tickets_path, class: "w-9 h-9 flex items-center justify-center rounded-xl bg-surface-container border border-outline-variant/20 hover:border-primary/30 text-on-surface-variant hover:text-primary transition-all shrink-0 mt-0.5" do %>
      <span class="material-symbols-outlined text-xl">arrow_back</span>
    <% end %>
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold text-on-surface truncate"><%= @ticket.title %></h1>
      <div class="flex flex-wrap gap-2 mt-2">
        <span class="chip <%= case @ticket.status
            when 'open'        then 'chip-emerald'
            when 'in_progress' then 'chip-yellow'
            when 'resolved'    then 'chip-blue'
            end %>">
          <%= @ticket.status_label %>
        </span>
        <span class="chip <%= case @ticket.priority
            when 'low'    then 'chip-gray'
            when 'medium' then 'chip-yellow'
            when 'high'   then 'chip-red'
            end %>">
          <%= @ticket.priority_label %>
        </span>
        <span class="chip <%= case @ticket.sla_status
            when 'atrasado'  then 'chip-red'
            when 'vencendo'  then 'chip-yellow'
            when 'no prazo'  then 'chip-emerald'
            when 'resolvido' then 'chip-blue'
            else 'chip-gray'
            end %>">
          SLA: <%= @ticket.sla_status_label %>
        </span>
      </div>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= link_to edit_ticket_path(@ticket),
        class: "h-9 px-4 flex items-center gap-1.5 bg-surface-container border border-outline-variant/20 text-on-surface-variant text-xs font-semibold rounded-xl hover:border-primary/30 hover:text-primary transition-all" do %>
        <span class="material-symbols-outlined text-base">edit</span>
        Editar
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Description -->
      <div class="bg-surface-container border border-outline-variant/20 rounded-2xl p-6">
        <h2 class="text-sm font-semibold text-on-surface mb-3 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-base">description</span>
          Descrição
        </h2>
        <p class="text-sm text-on-surface-variant leading-relaxed"><%= @ticket.description %></p>
      </div>

      <!-- Attachments -->
      <% if @ticket.attachments.attached? %>
        <div class="bg-surface-container border border-outline-variant/20 rounded-2xl p-6">
          <h2 class="text-sm font-semibold text-on-surface mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-base">attach_file</span>
            Anexos
          </h2>
          <div class="space-y-2">
            <% @ticket.attachments.each do |attachment| %>
              <div class="flex items-center justify-between p-3 bg-surface-container-low border border-outline-variant/20 rounded-xl">
                <div class="flex items-center gap-2 min-w-0">
                  <span class="material-symbols-outlined text-outline text-base">draft</span>
                  <span class="text-sm text-on-surface truncate"><%= attachment.filename %></span>
                </div>
                <%= link_to rails_blob_path(attachment, disposition: "attachment"),
                  class: "text-xs font-semibold text-primary hover:underline underline-offset-2 shrink-0 ml-2" do %>
                  Baixar
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Comments -->
      <div class="bg-surface-container border border-outline-variant/20 rounded-2xl p-6">
        <h2 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-base">chat</span>
          Comentários
        </h2>

        <% if @ticket.comments.any? %>
          <div class="space-y-3 mb-6">
            <% @ticket.comments.order(created_at: :desc).each do |comment| %>
              <div class="p-4 bg-surface-container-low border border-outline-variant/20 rounded-xl">
                <p class="text-sm text-on-surface leading-relaxed"><%= comment.content %></p>
                <p class="text-xs text-on-surface-variant mt-2 flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs">person</span>
                  <%= comment.user.email %>
                </p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-on-surface-variant mb-6">Nenhum comentário ainda.</p>
        <% end %>

        <%= form_with(model: [@ticket, Comment.new], local: true, class: "space-y-3") do |form| %>
          <%= form.text_area :content,
            rows: 3,
            placeholder: "Adicione um comentário...",
            class: "w-full bg-surface-container-low border border-outline-variant/40 rounded-xl px-4 py-3 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all resize-none" %>
          <%= form.submit "Comentar",
            class: "h-9 px-5 gradient-emerald text-on-primary text-xs font-bold rounded-xl shadow-primary/20 transition-all cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <!-- Sidebar info -->
    <div class="space-y-6">
      <!-- Activity -->
      <div class="bg-surface-container border border-outline-variant/20 rounded-2xl p-6">
        <h2 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-base">history</span>
          Histórico
        </h2>

        <% if @ticket.activities.any? %>
          <div class="space-y-3">
            <% @ticket.activities.order(created_at: :desc).each do |activity| %>
              <div class="border-l-2 border-primary/30 pl-3 py-1">
                <p class="text-xs text-on-surface leading-relaxed">
                  <span class="font-semibold text-primary"><%= activity.user.email %></span>
                  <%= activity.action %>
                </p>
                <p class="text-xs text-on-surface-variant mt-0.5">
                  <%= l(activity.created_at, format: :short) %>
                </p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-xs text-on-surface-variant">Nenhuma atividade registrada.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="bg-background text-on-background min-h-screen flex items-center justify-center px-4 relative overflow-hidden">
  <div class="absolute inset-0 dotted-grid opacity-5 pointer-events-none"></div>
  <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/10 rounded-full blur-[120px]"></div>

  <div class="relative z-10 w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 text-xl font-bold text-primary">
        <span class="material-symbols-outlined">bolt</span>
        HelpDesk Pro
      </a>
    </div>

    <div class="bg-surface-container border border-outline-variant/30 rounded-2xl px-8 py-10 shadow-2xl shadow-black/40">
      <div class="flex justify-center mb-6">
        <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary text-3xl">mark_email_read</span>
        </div>
      </div>

      <div class="text-center mb-8">
        <p class="text-xs font-medium text-outline uppercase tracking-widest mb-1">Confirmação</p>
        <h2 class="text-2xl font-bold text-on-surface">Reenviar confirmação</h2>
        <p class="text-sm text-on-surface-variant mt-2">Informe seu e-mail para reenviar as instruções de confirmação.</p>
      </div>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, "E-mail",
            class: "block text-sm font-medium text-on-surface-variant mb-2" %>
          <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
            placeholder: "nome@empresa.com",
            class: "w-full h-12 bg-surface-container-low border border-outline-variant/40 rounded-xl px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all duration-200" %>
        </div>

        <%= f.submit "Reenviar instruções",
          class: "w-full h-12 gradient-emerald text-on-primary text-sm font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/30 active:scale-[0.98] transition-all duration-200 cursor-pointer" %>
      <% end %>

      <div class="mt-8 text-center">
        <%= link_to "Voltar ao login",
          new_session_path(resource_name),
          class: "text-sm font-bold text-primary hover:underline underline-offset-4" %>
      </div>
    </div>
  </div>
</div>

<div class="bg-background text-on-background min-h-screen flex selection:bg-primary/30">
  <main class="flex w-full min-h-screen overflow-hidden">

    <!-- Left Side: Branding -->
    <section class="hidden lg:flex flex-col w-1/2 relative bg-[#1A1A1A] p-16 overflow-hidden border-r border-outline-variant/30">
      <div class="absolute inset-0 dotted-grid opacity-10 pointer-events-none"></div>
      <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 right-0 w-full h-1/2 bg-gradient-to-t from-primary/5 to-transparent"></div>

      <div class="relative z-10 mb-16">
        <h1 class="text-2xl font-bold text-primary flex items-center gap-2">
          <span class="material-symbols-outlined">bolt</span>
          HelpDesk Pro
        </h1>
      </div>

      <div class="relative z-10 flex-grow flex flex-col justify-center max-w-xl">
        <h2 class="text-5xl font-bold text-on-surface mb-4 leading-tight tracking-tight">
          Comece agora gratuitamente
        </h2>
        <p class="text-lg text-on-surface-variant mb-12 leading-relaxed">
          Crie sua conta e tenha acesso completo ao sistema de gestão de chamados mais eficiente para equipes modernas.
        </p>

        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
            </div>
            <p class="text-on-surface-variant text-sm">Configuração em menos de 2 minutos</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
            </div>
            <p class="text-on-surface-variant text-sm">Controle total de SLAs e prioridades</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
            </div>
            <p class="text-on-surface-variant text-sm">Dashboard com métricas em tempo real</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Right Side: Registration Form -->
    <section class="w-full lg:w-1/2 flex flex-col items-center justify-center bg-on-surface px-4 lg:px-16 relative">
      <div class="lg:hidden absolute top-10 left-4">
        <h1 class="text-2xl font-bold text-inverse-primary flex items-center gap-2">
          <span class="material-symbols-outlined">bolt</span>
          HelpDesk Pro
        </h1>
      </div>

      <div class="w-full max-w-md bg-white rounded-[2rem] px-10 py-12 shadow-xl shadow-black/5 group">
        <div class="mb-6 flex justify-center">
          <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <span class="material-symbols-outlined text-primary text-3xl">person_add</span>
          </div>
        </div>

        <div class="text-center mb-8">
          <p class="text-xs font-medium text-outline uppercase tracking-widest mb-1">Cadastro</p>
          <h2 class="text-2xl font-bold text-[#1A1A1A]">Criar sua conta</h2>
        </div>

        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
          <div>
            <%= f.label :email, "E-mail",
              class: "block text-sm font-medium text-surface-variant mb-2" %>
            <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "nome@empresa.com",
              class: "w-full h-12 bg-white border border-outline-variant/30 rounded-xl px-4 text-sm text-[#1A1A1A] focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all duration-200" %>
          </div>

          <div>
            <%= f.label :password, "Senha",
              class: "block text-sm font-medium text-surface-variant mb-2" %>
            <div class="relative">
              <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "••••••••",
                id: "reg_password",
                class: "w-full h-12 bg-white border border-outline-variant/30 rounded-xl px-4 text-sm text-[#1A1A1A] focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all duration-200" %>
              <button type="button" onclick="toggleVis('reg_password','reg_icon')" class="absolute right-4 top-1/2 -translate-y-1/2 text-outline hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-xl" id="reg_icon">visibility</span>
              </button>
            </div>
            <% if @minimum_password_length %>
              <p class="text-xs text-outline mt-1">Mínimo de <%= @minimum_password_length %> caracteres.</p>
            <% end %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirmar senha",
              class: "block text-sm font-medium text-surface-variant mb-2" %>
            <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "w-full h-12 bg-white border border-outline-variant/30 rounded-xl px-4 text-sm text-[#1A1A1A] focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all duration-200" %>
          </div>

          <%= f.submit "Criar conta",
            class: "w-full h-12 gradient-emerald text-on-primary text-sm font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/30 active:scale-[0.98] transition-all duration-200 cursor-pointer" %>
        <% end %>

        <div class="mt-8 text-center">
          <p class="text-sm text-surface-variant">
            Já tem uma conta?
            <%= link_to "Entrar",
              new_session_path(resource_name),
              class: "font-bold text-primary hover:underline underline-offset-4 ml-1" %>
          </p>
        </div>
      </div>

      <div class="absolute bottom-6 text-center">
        <p class="text-xs text-outline">
          &copy; <%= Time.current.year %> HelpDesk Pro. Enterprise Infrastructure.
        </p>
      </div>
    </section>
  </main>
</div>

<script>
  function toggleVis(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (input.type === 'password') {
      input.type = 'text';
      icon.textContent = 'visibility_off';
    } else {
      input.type = 'password';
      icon.textContent = 'visibility';
    }
  }
</script>

<!DOCTYPE html>
<html>
  <head>
    <title>HelpDesk Pro</title>

    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js"></script>

    <%= javascript_importmap_tags %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Geist:wght@400;500&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>

    <%# Apply saved theme before first paint to avoid flash %>
    <script>
      (function() {
        var theme = localStorage.getItem('helpdesk-theme') || 'dark';
        if (theme === 'light') document.documentElement.classList.add('theme-light-pending');
      })();
    </script>
    <style>
      html.theme-light-pending body { visibility: hidden; }
    </style>
  </head>

  <body class="bg-background text-on-surface font-[Inter]">
    <script>
      (function() {
        var theme = localStorage.getItem('helpdesk-theme') || 'dark';
        if (theme === 'light') {
          document.body.classList.add('light-mode');
          document.documentElement.classList.remove('theme-light-pending');
        }
        document.body.style.visibility = '';
      })();
    </script>

    <%= turbo_stream_from "notifications_#{current_user.id}" if user_signed_in? %>

    <% if user_signed_in? %>
      <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 bg-[#141718] text-on-surface flex flex-col border-r border-white/5 shrink-0">
          <!-- Brand -->
          <div class="px-6 py-6 border-b border-white/5">
            <h1 class="text-xl font-bold text-primary flex items-center gap-2">
              <span class="material-symbols-outlined">bolt</span>
              HelpDesk Pro
            </h1>
            <p class="text-xs text-white/40 mt-1">Sistema de Chamados</p>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-4 py-6 space-y-1">
            <%= link_to dashboard_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-white/50 hover:bg-white/5 hover:text-primary transition-all duration-200 group" do %>
              <span class="material-symbols-outlined text-xl group-hover:text-primary transition-colors">dashboard</span>
              Dashboard
            <% end %>

            <%= link_to tickets_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-white/50 hover:bg-white/5 hover:text-primary transition-all duration-200 group" do %>
              <span class="material-symbols-outlined text-xl group-hover:text-primary transition-colors">confirmation_number</span>
              Chamados
            <% end %>

            <%= link_to new_ticket_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-white/50 hover:bg-white/5 hover:text-primary transition-all duration-200 group" do %>
              <span class="material-symbols-outlined text-xl group-hover:text-primary transition-colors">add_circle</span>
              Novo Chamado
            <% end %>

            <%= link_to notifications_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-white/50 hover:bg-white/5 hover:text-primary transition-all duration-200 group" do %>
              <span class="material-symbols-outlined text-xl group-hover:text-primary transition-colors">notifications</span>
              Notificações
              <span id="notifications_count" class="ml-auto">
                <%= render "notifications/count", user: current_user %>
              </span>
            <% end %>
          </nav>

          <!-- Theme toggle + User footer -->
          <div class="px-4 py-4 border-t border-white/5 space-y-2">
            <!-- Theme toggle button -->
            <button
              id="theme-toggle"
              onclick="toggleTheme()"
              class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-white/50 hover:bg-white/5 hover:text-primary transition-all duration-200 cursor-pointer">
              <span class="material-symbols-outlined text-xl" id="theme-icon">light_mode</span>
              <span id="theme-label">Modo claro</span>
            </button>

            <!-- User info -->
            <div class="flex items-center gap-3 px-3 py-2 rounded-xl bg-white/5">
              <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary text-base">person</span>
              </div>
              <p class="text-xs text-white/40 truncate"><%= current_user.email %></p>
            </div>

            <%= button_to destroy_user_session_path,
              method: :delete,
              class: "w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-red-400/60 hover:bg-red-500/10 hover:text-red-400 transition-all duration-200 cursor-pointer" do %>
              <span class="material-symbols-outlined text-xl">logout</span>
              Sair
            <% end %>
          </div>
        </aside>

        <!-- Main content -->
        <main class="flex-1 flex flex-col overflow-hidden relative surface-pattern">
          <div class="absolute top-0 right-0 w-[600px] h-[400px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
          <div class="absolute bottom-0 left-1/4 w-[400px] h-[300px] bg-primary/4 rounded-full blur-[100px] pointer-events-none"></div>
          <!-- Top bar -->
          <div class="bg-surface-container-low border-b border-outline-variant/20 px-8 py-4 flex justify-between items-center">
            <h2 class="text-sm font-semibold text-on-surface-variant">Sistema de Gestão de Chamados</h2>
            <div class="flex items-center gap-2 text-xs text-on-surface-variant">
              <span class="w-2 h-2 bg-primary rounded-full"></span>
              Online
            </div>
          </div>

          <!-- Alerts -->
          <% if notice.present? %>
            <div class="mx-8 mt-4 bg-primary/10 border border-primary/30 text-primary px-4 py-3 rounded-xl text-sm flex items-center gap-2">
              <span class="material-symbols-outlined text-base">check_circle</span>
              <%= notice %>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="mx-8 mt-4 bg-error-container/20 border border-error/30 text-error px-4 py-3 rounded-xl text-sm flex items-center gap-2">
              <span class="material-symbols-outlined text-base">error</span>
              <%= alert %>
            </div>
          <% end %>

          <div class="flex-1 overflow-auto relative z-10">
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <%= yield %>
    <% end %>

    <script>
      function toggleTheme() {
        var body = document.body;
        var isLight = body.classList.toggle('light-mode');
        localStorage.setItem('helpdesk-theme', isLight ? 'light' : 'dark');
        updateThemeButton(isLight);
      }

      function updateThemeButton(isLight) {
        var icon  = document.getElementById('theme-icon');
        var label = document.getElementById('theme-label');
        if (!icon || !label) return;
        if (isLight) {
          icon.textContent  = 'dark_mode';
          label.textContent = 'Modo escuro';
        } else {
          icon.textContent  = 'light_mode';
          label.textContent = 'Modo claro';
        }
      }

      // Sync button state with current theme on load
      document.addEventListener('DOMContentLoaded', function() {
        var isLight = document.body.classList.contains('light-mode');
        updateThemeButton(isLight);
      });
    </script>
  </body>
</html>
